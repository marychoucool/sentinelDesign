flowchart TD
    %% ===== Users =====
    NormalUser["Normal User"]
    AdminUser["Admin User"]
    RootUser["Root User"]

    %% ===== Frontend Containers =====
    subgraph Frontend ["Client Applications"]
        FrontendApp["Frontend App<br>(Desktop/iOS/Android)"]
    end

    %% ===== System Boundary =====
    subgraph Backend ["Sentinel Server<br>(On-Premise)"]
        %% ===== Backend API =====
        BackendAPI["Backend API<br>(NestJS + Local Storage + Monitoring)"]

        %% ===== Services =====
        ASRService["ASR Service<br>: Streaming + Batch Speech to Text"]
        LLMService["LLM Batch Service<br>: Summary / Action / Embedding"]
        ChatService["Chat Service<br>: Chat Query Processing"]

        %% ===== Data Stores =====
        Database["Database<br>(PostgreSQL + pgvector)"]
        WorkflowEngine["Workflow Engine<br>(Temporal.io / BullMQ)"]
    end

    %% ===== User to Frontend =====
    NormalUser --> FrontendApp
    AdminUser --> FrontendApp
    RootUser --> FrontendApp

    %% ===== Frontend to Backend =====
    FrontendApp -->|"WebSocket<br>(實時音訊串流 + Chat Streaming)"| BackendAPI
    FrontendApp -->|"HTTPS / REST API<br>(錄音/上傳/其他查詢)"| BackendAPI
    BackendAPI -->|"WebSocket<br>(推送監控數據)"| FrontendApp

    %% ===== Backend Internal (Real-time Streaming) =====
    BackendAPI -->|"gRPC Streaming<br>(錄音中)"| ASRService
    ASRService -->|"推送逐字稿"| BackendAPI

    %% ===== Backend Internal (Batch Processing) =====
    BackendAPI -->|"Start Workflow<br>(ASR → LLM)"| WorkflowEngine
    BackendAPI -->|"WebSocket Streaming<br>(Chat 查詢)"| ChatService

    %% ===== Workflow Processing =====
    WorkflowEngine -->|"Activity<br>: ASR Batch"| ASRService
    WorkflowEngine -->|"Activity<br>: LLM Batch"| LLMService
    ASRService -->|"Workflow Signal<br>(完成 → 觸發 LLM)"| WorkflowEngine

    %% ===== Service to Database (TCP/Connection Pool) =====
    ASRService -->|"SQL<br>(儲存逐字稿)"| Database
    LLMService -->|"SQL<br>(儲存結果)"| Database
    ChatService -->|"SQL<br>(查詢/寫入)"| Database
    BackendAPI -->|"SQL<br>(資料查詢)"| Database

    %% ===== Storage Access =====
    ASRService -->|"HTTP<br>(讀取音檔)"| BackendAPI
