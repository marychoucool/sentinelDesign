flowchart TD
    %% ===== Users =====
    NormalUser["Normal User"]
    AdminUser["Admin User"]
    RootUser["Root User"]

    %% ===== Frontend Containers =====
    subgraph Frontend ["Client Applications"]
        FrontendApp["Frontend App<br>(Desktop/iOS/Android)"]
    end

    %% ===== Cloud Systems (Outside Sentinel Server) =====
    subgraph Cloud ["Cloud Infrastructure (SaaS)"]
        RelayEndpoint["Relay Endpoint<br>(NAT Traversal)"]
        AuthAPI["Auth API (SaaS)<br>(JWT Signing)"]
        DeviceRegistry["Device Registry (SaaS)<br>(Serial → Tenant)"]
    end

    %% ===== On-Premise System =====
    subgraph Backend ["Sentinel Server<br>(On-Premise)"]
        %% ===== Tunnel Client =====
        TunnelClient["Tunnel Client<br>(Outbound Agent)"]

        %% ===== Backend API =====
        BackendAPI["Backend API<br>(NestJS + Local JWT Validation + Monitoring)"]

        %% ===== Services =====
        ASRService["ASR Service<br>: Batch Speech to Text"]
        LLMService["LLM Batch Service<br>: Summary / Action / Embedding"]
        ChatService["Chat Service<br>: Chat Query Processing (WebSocket)"]

        %% ===== Data Stores =====
        Database["Database<br>(PostgreSQL + pgvector)<br>(含 jobs 表)"]
    end

    %% ===== User to Frontend =====
    NormalUser --> FrontendApp
    AdminUser --> FrontendApp
    RootUser --> FrontendApp

    %% ===== Frontend → Cloud (Auth + Relay) =====
    FrontendApp -->|"HTTPS / Login / Refresh JWT"| AuthAPI
    FrontendApp -->|"HTTPS / Bind Device"| DeviceRegistry
    FrontendApp -->|"HTTPS / Upload Audio<br>/ WebSocket / Chat Streaming"| RelayEndpoint

    %% ===== Cloud → On-Prem (Relay path) =====
    RelayEndpoint -->|"Relay Traffic"| TunnelClient
    TunnelClient -->|"Local Forward"| BackendAPI

    %% ===== On-Prem (Tunnel Client → Relay) =====
    TunnelClient -.->|"Outbound Tunnel"| RelayEndpoint

    %% ===== Server → SaaS (Registration only) =====
    BackendAPI -.->|"HTTPS / Auto-Register Serial"| DeviceRegistry
    BackendAPI -.->|"HTTPS / Poll Binding Status"| DeviceRegistry

    %% ===== Root User Direct (for debugging) =====
    RootUser -.->|"Direct LAN Access (HTTPS)"| BackendAPI


    %% ===== Backend Internal (WebSocket for Chat only) =====
    BackendAPI -->|"WebSocket Streaming<br>(Chat 查詢)"| ChatService

    %% ===== Async Job Processing =====
    BackendAPI -->|"INSERT Job (pending)"| Database
    ASRService -->|"Poll ASR Jobs<br>SELECT & UPDATE"| Database
    LLMService -->|"Poll LLM Jobs<br>SELECT & UPDATE"| Database

    %% ===== Service to Database (TCP/Connection Pool) =====
    ASRService -->|"SQL<br>(儲存逐字稿)"| Database
    LLMService -->|"SQL<br>(儲存結果)"| Database
    ChatService -->|"SQL<br>(查詢/寫入)"| Database
    BackendAPI -->|"SQL<br>(資料查詢)"| Database
