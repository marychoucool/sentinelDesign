    %% ===== Users =====
    NormalUser["Normal User<br>(Mobile / Laptop)"]
    AdminUser["Admin User<br>(Dashboard)"]
    RootUser["Root User<br>(Debug / Dev)"]

    %% ===== External Cloud Systems =====
    subgraph Cloud ["Cloud Infrastructure (SaaS/IDC)"]
        RelayService["Relay Service<br>(純 TCP 轉發)"]
        DeviceRegistry["Device Registry<br>(Email → Tenant)"]
    end

    %% ===== On-Premise System =====
    SentinelServer["Sentinel Server<br>(On-Premise + Auth)"]

    %% ===== User → Relay → Server (Data flows) =====
    NormalUser -->|"Audio / Chat (外網)"| RelayService
    RelayService -->|"Relay Traffic"| SentinelServer
    AdminUser -->|"Monitor / Setup (外網)"| RelayService

    %% ===== Direct LAN Access =====
    NormalUser -.->|"Audio / Chat (區網)"| SentinelServer
    AdminUser -.->|"Monitor / Setup (區網)"| SentinelServer

    %% ===== Sentinel → Device Registry =====
    SentinelServer -.->|"註冊使用者"| DeviceRegistry

    %% ===== Root User Direct =====
    RootUser -->|"Debug / 全權限存取"| SentinelServer